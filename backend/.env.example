# ===== FastAPI Configuration =====
FASTAPI_ENV=development
# Options: development, staging, production

# ===== CORS Configuration (comma-separated URLs) =====
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example: https://your-frontend.netlify.app

# ===== Database Configuration (Optional) =====
DATABASE_URL=postgresql://username:password@localhost:5432/creditpath_db
# Format: postgresql://user:password@host:port/database_name
# For Render: provided automatically as DATABASE_URL env var

# ===== Server Configuration =====
HOST=0.0.0.0
PORT=8000

# ===== Optional: API Keys & Secrets =====
# SECRET_KEY=your-secret-key-here
# API_KEY=your-api-key-here

